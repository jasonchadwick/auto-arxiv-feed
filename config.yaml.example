# ---------------------------------------------------------------------------
# auto-arxiv-feed configuration
# Copy this file to config.yaml and fill in your credentials.
# ---------------------------------------------------------------------------

# ── Zotero ──────────────────────────────────────────────────────────────────
zotero:
  user_id: "YOUR_ZOTERO_USER_ID"      # numeric ID from zotero.org/settings/keys
  api_key: "YOUR_ZOTERO_API_KEY"      # create a key at zotero.org/settings/keys
  library_type: "user"                # "user" or "group"

# ── arXiv categories to monitor ─────────────────────────────────────────────
arxiv:
  categories:
    - "quant-ph"
    - "cs.ET"
    # Add more arXiv category identifiers as needed, e.g.:
    # - "cond-mat.mes-hall"
    # - "cs.LG"

# ── Embedding provider ───────────────────────────────────────────────────────
# provider: "openai" | "gemini" | "local"
# (Anthropic/Claude is listed for completeness but has no embedding API yet.)
embedding:
  provider: "openai"
  model: "text-embedding-3-small"       # OpenAI model names:
                                        #   text-embedding-3-small (fastest/cheapest)
                                        #   text-embedding-3-large (higher quality)
                                        # Gemini model names:
                                        #   models/text-embedding-004
                                        # Local model names (sentence-transformers):
                                        #   BAAI/bge-small-en-v1.5  (default, ~133 MB)
                                        #   BAAI/bge-large-en-v1.5  (~1.3 GB, best quality)
                                        #   allenai-specter         (~400 MB, scientific papers)
                                        #   all-MiniLM-L6-v2        (~22 MB, ultra-fast)
  # API keys below are optional if the matching environment variables are set.
  openai_api_key: ""     # or set OPENAI_API_KEY env var
  gemini_api_key: ""     # or set GEMINI_API_KEY / GOOGLE_API_KEY env var
  # No API key needed for provider: local

# ── Local database ───────────────────────────────────────────────────────────
database:
  path: "papers.db"

# ── Relevance thresholds ─────────────────────────────────────────────────────
relevance:
  # LOF density-score threshold (0 to 1). Papers whose embedding has inlier-like
  # local density with respect to your library above this value are included.
  # Typical starting point: 0.50. Use --dry-run --threshold X to experiment.
  threshold: 0.50
  # Number of neighbors used by LOF for local density estimation.
  # Typical range: 10-50. Higher values make scoring more global/smoother.
  lof_neighbors: 20
  top_k: 5    # number of cosine-nearest library papers shown per result
  # Papers whose title or abstract contains any of these terms are always
  # included in the digest (case-insensitive sanity check).
  always_include_terms: []
  # Example:
  # always_include_terms: ["error correction", "superconducting qubit"]

  # Collections to exclude from LOF clustering (matched by name, case-insensitive,
  # applied recursively to all subcollections).  A paper is only excluded if
  # ALL of its collections are excluded; a paper in both an excluded and a
  # non-excluded collection is still included.
  excluded_collections: []
  # Example:
  # excluded_collections: ["reading list", "archive"]

# ── Email digest ─────────────────────────────────────────────────────────────
# Leave smtp_host empty (or omit the whole email block) to print the digest
# to stdout instead of sending email.
email:
  smtp_host: "smtp.gmail.com"
  smtp_port: 587
  smtp_user: "your@gmail.com"
  smtp_password: ""     # or set EMAIL_PASSWORD env var
  from_address: "your@gmail.com"
  to_address: "your@gmail.com"
  subject_prefix: "[arXiv Feed]"
